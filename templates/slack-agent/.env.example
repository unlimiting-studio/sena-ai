# Slack Socket Mode
SLACK_APP_TOKEN=xapp-...
SLACK_BOT_TOKEN=xoxb-...

# Postgres for chat-sdk subscriptions / locks / queues
DATABASE_URL=postgres://user:password@host:5432/db

# Provider-specific keys are handled by the provider package / CLI environment.
# Example: Anthropic/Claude Code login or provider env expected by ai-sdk-provider-claude-code.
