{
  "name": "@sena-ai/app",
  "version": "0.1.0",
  "description": "sena-ai v3 — 얇은 앱 레이어 (chat-sdk wrapper + ai-sdk middleware + schedules + steering)",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./middlewares": {
      "types": "./dist/middlewares/index.d.ts",
      "import": "./dist/middlewares/index.js"
    },
    "./schedules": {
      "types": "./dist/schedules/index.d.ts",
      "import": "./dist/schedules/index.js"
    },
    "./adapters/slack": {
      "types": "./dist/adapters/slack.d.ts",
      "import": "./dist/adapters/slack.js"
    },
    "./state": {
      "types": "./dist/state/index.d.ts",
      "import": "./dist/state/index.js"
    },
    "./state/postgres": {
      "types": "./dist/state/postgres.d.ts",
      "import": "./dist/state/postgres.js"
    },
    "./state/memory": {
      "types": "./dist/state/memory.d.ts",
      "import": "./dist/state/memory.js"
    },
    "./middlewares/channel-context": {
      "types": "./dist/middlewares/channel-context.d.ts",
      "import": "./dist/middlewares/channel-context.js"
    },
    "./middlewares/trace": {
      "types": "./dist/middlewares/trace.d.ts",
      "import": "./dist/middlewares/trace.js"
    },
    "./schedules/cron": {
      "types": "./dist/schedules/cron.d.ts",
      "import": "./dist/schedules/cron.js"
    },
    "./env": {
      "types": "./dist/env.d.ts",
      "import": "./dist/env.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ai": "^6.0.177",
    "@ai-sdk/provider": "^3.0.0",
    "chat": "^4.28.1",
    "@chat-adapter/slack": "^4.28.1",
    "@chat-adapter/state-memory": "^4.28.1",
    "@chat-adapter/state-pg": "^4.28.1",
    "node-cron": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unlimiting-studio/sena-ai.git",
    "directory": "packages/app"
  }
}
