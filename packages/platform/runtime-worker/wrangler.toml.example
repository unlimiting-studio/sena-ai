name = "sena-platform"
main = "src/index.ts"
compatibility_date = "2024-12-01"

[vars]
PLATFORM_BASE_URL = "https://your-worker.your-subdomain.workers.dev"
SLACK_WORKSPACE_ID = "default"

# Secrets (set via `wrangler secret put`):
# VAULT_MASTER_KEY
# SLACK_CONFIG_TOKEN
# SLACK_CONFIG_REFRESH_TOKEN

[[d1_databases]]
binding = "DB"
database_name = "sena-platform"
database_id = "<YOUR_D1_DATABASE_ID>"  # Run: wrangler d1 create sena-platform

[durable_objects]
bindings = [
  { name = "RELAY_DO", class_name = "RelayDurableObject" }
]

[[migrations]]
tag = "v1"
new_classes = ["RelayDurableObject"]

[triggers]
crons = ["0 */10 * * *"]
