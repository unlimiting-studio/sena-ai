{
  "name": "sena",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "dev": "tsx --watch src/index.ts",
    "build": "esbuild src/index.ts src/worker/index.ts --bundle --outdir=dist --platform=node --target=node22 --format=esm --packages=external",
    "check": "pnpm check:lint && pnpm check:type",
    "check:lint": "biome lint",
    "check:type": "tsc --noEmit",
    "fix": "biome format --write && biome lint --write"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.76",
    "@fastify/formbody": "^8.0.2",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@octokit/rest": "^22.0.1",
    "@openai/codex-sdk": "^0.99.0",
    "@slack/web-api": "^7.13.0",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.44.7",
    "fastify": "^5.6.2",
    "fastify-raw-body": "^5.0.0",
    "json5": "^2.2.3",
    "mysql2": "^3.16.0",
    "yaml": "^2.8.2",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.10",
    "@slack/types": "^2.19.0",
    "@types/node": "^25.0.3",
    "esbuild": "^0.25.12",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
