{
  "name": "sena",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "dev": "tsx --watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --outfile=dist/index.js --platform=node --target=node24 --format=esm --packages=external",
    "check": "pnpm check:lint && pnpm check:type",
    "check:lint": "biome lint",
    "check:type": "tsc --noEmit",
    "fix": "biome format --write && biome lint --write"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.72",
    "@fastify/formbody": "^8.0.2",
    "@octokit/rest": "^22.0.1",
    "@slack/web-api": "^7.13.0",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.44.7",
    "fastify": "^5.6.2",
    "fastify-raw-body": "^5.0.0",
    "mysql2": "^3.16.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.10",
    "@types/node": "^25.0.3",
    "esbuild": "^0.25.12",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
